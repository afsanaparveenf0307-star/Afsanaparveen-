<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>SkillSprint - Student Activity Tracker</title>

<style>

/* BODY BACKGROUND */

body{
margin:0;
font-family: 'Segoe UI', sans-serif;
background:linear-gradient(135deg,#3b0000,#800000,#ffffff);
min-height:100vh;
}

/* HEADER */

header{
background:linear-gradient(90deg,#2b0000,#800000);
color:white;
text-align:center;
padding:25px;
letter-spacing:1px;
box-shadow:0 4px 10px rgba(0,0,0,0.4);
}

header h1{
margin:0;
font-size:60px;      /* BIG TITLE */
font-weight:bold;    /* BOLD TEXT */
letter-spacing:3px;
text-transform:uppercase;
}

/* NAVIGATION */

nav{
display:flex;
justify-content:center;
background:#3b0000;
padding:12px;
}

nav a{
color:white;
text-decoration:none;
margin:0 15px;
padding:8px 18px;
border-radius:25px;
background:#800000;
transition:0.3s;
}

nav a:hover{
background:white;
color:#800000;
}

/* MAIN CONTAINER */

.container{
width:85%;
margin:40px auto;
background:rgba(255,255,255,0.95);
padding:35px;
border-radius:15px;
box-shadow:0 8px 20px rgba(0,0,0,0.4);
}

/* HOME SECTION */

.home{
text-align:center;
background:#fff0f0;
padding:25px;
border-radius:12px;
margin-bottom:35px;
}

.home h2{
color:#800000;
}

/* ACTIVITY GRID */

.activities{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
gap:25px;
}

/* CARD STYLE */

.card{
background:linear-gradient(145deg,#ffffff,#ffe6e6);
padding:20px;
border-radius:12px;
box-shadow:0 6px 15px rgba(0,0,0,0.2);
transition:0.3s;
}

.card:hover{
transform:translateY(-6px);
box-shadow:0 10px 20px rgba(0,0,0,0.3);
}

.card h3{
color:#800000;
margin-top:0;
}

.status{
font-weight:bold;
color:#800000;
}

/* BUTTON STYLE */

button{
background:linear-gradient(90deg,#800000,#a80000);
color:white;
border:none;
padding:8px 14px;
margin-top:10px;
border-radius:20px;
cursor:pointer;
transition:0.3s;
}

button:hover{
background:white;
color:#800000;
border:1px solid #800000;
}

/* PROGRESS SECTION */

.progress-section{
margin-top:40px;
text-align:center;
}

.progress-bar{
width:100%;
background:#eee;
height:22px;
border-radius:25px;
overflow:hidden;
margin-top:10px;
}

.progress{
height:100%;
width:0%;
background:linear-gradient(90deg,#800000,#b30000);
transition:0.4s;
}

/* FOOTER */

footer{
text-align:center;
padding:15px;
background:#3b0000;
color:white;
margin-top:30px;
}

</style>
</head>

<body>

<header>
<h1>SkillSprint</h1>
<p>Student Activity Tracker</p>
</header>

<nav>
<a href="#">Home</a>
<a href="#">Activities</a>
<a href="#">Progress</a>
</nav>

<div class="container">

<div class="home">
<h2>Welcome to SkillSprint</h2>
<p>Track your daily learning goals and monitor your progress easily.</p>
</div>

<h2 style="color:#800000;">Activity List</h2>

<div class="activities">

<div class="card">
<h3>HTML Basics</h3>
<p>Learn the structure of web pages using HTML.</p>
<p>Status: <span class="status">Pending</span></p>
<button onclick="completeTask(this)">Mark Completed</button>
</div>

<div class="card">
<h3>CSS Styling</h3>
<p>Design beautiful web layouts using CSS.</p>
<p>Status: <span class="status">Pending</span></p>
<button onclick="completeTask(this)">Mark Completed</button>
</div>

<div class="card">
<h3>JavaScript Basics</h3>
<p>Understand interactive web programming.</p>
<p>Status: <span class="status">Pending</span></p>
<button onclick="completeTask(this)">Mark Completed</button>
</div>

<div class="card">
<h3>Responsive Design</h3>
<p>Create mobile-friendly websites.</p>
<p>Status: <span class="status">Pending</span></p>
<button onclick="completeTask(this)">Mark Completed</button>
</div>

<div class="card">
<h3>Mini Project</h3>
<p>Build a small front-end project.</p>
<p>Status: <span class="status">Pending</span></p>
<button onclick="completeTask(this)">Mark Completed</button>
</div>

<div class="card">
<h3>Project Review</h3>
<p>Improve and finalize your project.</p>
<p>Status: <span class="status">Pending</span></p>
<button onclick="completeTask(this)">Mark Completed</button>
</div>

</div>

<div class="progress-section">

<h2 style="color:#800000;">Progress Summary</h2>

<p id="progressText">0 out of 6 activities completed</p>

<div class="progress-bar">
<div class="progress" id="progressBar"></div>
</div>

</div>

</div>

<footer>
<p>SkillSprint | Student Learning Tracker</p>
</footer>

<script>

function completeTask(button){

let status = button.parentElement.querySelector(".status");

if(status.innerText === "Pending"){

status.innerText = "Completed";
status.style.color="green";

button.disabled=true;

updateProgress();

}

}

function updateProgress(){

let statuses=document.querySelectorAll(".status");
let total=statuses.length;
let completed=0;

statuses.forEach(function(s){
if(s.innerText==="Completed"){
completed++;
}
});

document.getElementById("progressText").innerText=
completed+" out of "+total+" activities completed";

let percent=(completed/total)*100;

document.getElementById("progressBar").style.width=percent+"%";

}

</script>

</body>
</html>
